# نمونهٔ تنظیمات برای ربات و کانال Sepid (مقادیر حساس را خودتان پر کنید)

# از @BotFather برای @Sepid_Group_Bot
BOT_TOKEN=
BOT_USERNAME=Sepid_Group_Bot

# یوزرنیم کانال (بدون @) — برای لینک آگهی در متن پست
CHANNEL_USERNAME=Sepid_Exchange

# شناسهٔ عددی کانال @Sepid_Exchange (ربات باید ادمین کانال باشد)
# با @userinfobot یا getUpdates بعد از یک پیام در کانال پیدا می‌شود؛ معمولاً -100...
ADVERT_CHANNEL_ID=

# تلگرام آیدی عددی ادمین اصلی
ADMIN_USER_ID=

# نام فایل دیتابیس (پیش‌فرض eurobot.db)
DATABASE_NAME=eurobot.db

# اولین آگهی بعد از دیتابیس تازه (شمارهٔ نمایش در کانال)
ADVERT_ID_START=3196

# Twilio برای SMS ثبت‌نام
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM_PHONE_NUMBER=

# بعد از تأیید پیشنهاد — بدون @
DEAL_NEXT_STEPS_ADMIN=Sepid_Group_Admin

# اختیاری
# BOT_RESTART_COMMAND=systemctl restart telegram-bot
# BOT_RESTART_BROADCAST_MENU=1
