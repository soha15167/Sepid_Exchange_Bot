# نمونهٔ تنظیمات برای ربات و کانال Sepid (مقادیر حساس را خودتان پر کنید)

# از @BotFather برای @Sepid_Group_Bot
BOT_TOKEN=
BOT_USERNAME=Sepid_Group_Bot

# یوزرنیم کانال (بدون @) — برای لینک آگهی در متن پست
CHANNEL_USERNAME=Sepid_Exchange

# شناسهٔ عددی کانال @Sepid_Exchange (ربات باید ادمین کانال باشد)
# با @userinfobot یا getUpdates بعد از یک پیام در کانال پیدا می‌شود؛ معمولاً -100...
ADVERT_CHANNEL_ID=

# تلگرام آیدی عددی ادمین — پیام «ارسال به ادمین» و /admin همین چت @Sepid_Group_Bot است
# چند ادمین: 111,222  — از @userinfobot آیدی عددی خودتان را بگیرید
ADMIN_USER_ID=5809748588
# اختیاری: گروه ادمین برای کپی اعلان معامله (آیدی منفی گروه)
# DEAL_ADMIN_NOTIFY_CHAT_ID=

# نام فایل دیتابیس (پیش‌فرض eurobot.db)
DATABASE_NAME=eurobot.db

# اولین آگهی بعد از دیتابیس تازه (شمارهٔ نمایش در کانال)
ADVERT_ID_START=3196

# Twilio — فقط KEY=VALUE (کد پایتین Console را اینجا نچسبانید!)
# از Console → Account Info: Account SID و Auth Token
# از Verify → Service: Service SID (VA...)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
# نام داخل پیامک Verify (مثلاً Sepid Group به‌جای نام سرویس Console)
# نام در Console → Verify → Service تنظیم می‌شود (پیش‌فرض API بدون custom_friendly_name)
# TWILIO_VERIFY_FRIENDLY_NAME=Sepid_Group
# فقط اگر پلن Twilio اجازه دهد: TWILIO_VERIFY_USE_CUSTOM_NAME=1
# زبان قالب Verify در Console — fa = فارسی (برای +49 هم اگر locale=fa بفرستید)
# TWILIO_VERIFY_LOCALE=fa

# شمارهٔ فرستندهٔ پیامک کلاسیک (الزامی برای متن سفارشی زیر)
TWILIO_FROM_PHONE_NUMBER=
# با TWILIO_FROM پر = متن فارسی زیر (پیش‌فرض). برای Verify آلمانی: TWILIO_OTP_USE_CUSTOM_TEMPLATE=0
# TWILIO_OTP_USE_CUSTOM_TEMPLATE=1
SMS_OTP_BODY_TEMPLATE=به کانال Sepid_Exchange خوش آمدید.\nکد تأیید ثبت‌نام شما: {code}

# اختیاری — اگر SMS نشد، کد به ایمیل ثبت‌نام (Gmail: App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# بعد از تأیید پیشنهاد — بدون @
DEAL_NEXT_STEPS_ADMIN=Sepid_Group_Admin

# پست روزانه نرخ ارز بن‌بست (۱۲ ظهر تهران) — خالی = همان ADVERT_CHANNEL_ID
BONBAST_DAILY_POST_ENABLED=1
BONBAST_DAILY_HOUR=12
BONBAST_DAILY_MINUTE=0
BONBAST_CURRENCY_CODES=usd,eur,gbp,aed,try,chf,cad,sek
# BONBAST_CHANNEL_ID=

# اختیاری
# BOT_RESTART_COMMAND=systemctl restart telegram-bot
# BOT_RESTART_BROADCAST_MENU=1

# کارت‌های بانکی (فقط ادمین) — آرایه JSON
# نکته: این مقدار را در گیت commit نکنید.
# BANK_CARDS_JSON=[
#   {"id":"parsian","title":"پارسیان — حسن نصیری","card":"6221061238151536","iban":"IR8405402109201010992406C2"},
#   {"id":"maskan","title":"مسکن — حسن نصیری","card":"6280231559813224","iban":"IR440140040000710181570619"},
