# آدرس سایت مدیریت ورودی/خروجی ایران
# IRAN_PANEL_BASE_URL=http://49.13.132.230:8000

# خواندن رسید /txin و /txout با AI (دقیق‌تر از Tesseract)
# OpenAI (پولی):
# OPENAI_API_KEY=sk-...
# RECEIPT_VISION_MODEL=gpt-4o-mini
# RECEIPT_VISION_ENABLED=1
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# Ollama رایگان روی همان سرور (CPU کند؛ اولین بار مدل را pull کنید):
# RECEIPT_VISION_ENABLED=1
# RECEIPT_VISION_BASE_URL=http://127.0.0.1:11434/v1
# RECEIPT_VISION_MODEL=moondream
# (llama3.2-vision حدود 11GB RAM می‌خواهد — روی VPS 4GB مناسب نیست)
# RECEIPT_VISION_API_KEY=ollama
# RECEIPT_VISION_TIMEOUT_SEC=100
# روی VPS کم‌رم با Ollama: Vision پیش‌فرض خاموش (فقط OCR سریع)
# RECEIPT_VISION_USE_OLLAMA=1
